# ── Desenvolvimento local (npm start) ──────────────────────────────────────────
# Chave Groq usada SOMENTE em desenvolvimento. Em produção o proxy /api/ai usa GROQ_KEY no servidor.
REACT_APP_GROQ_KEY=gsk_sua_chave_aqui

# ── Build de produção (ver .env.production) ─────────────────────────────────────
# REACT_APP_API_URL=https://api.playnexusrpg.com   # domínio próprio (Vercel), ver docs/architecture

# ── Variáveis de ambiente Vercel (adicionar em vercel.com/dashboard > Settings > Environment Variables) ─────
# GROQ_KEY=gsk_sua_chave_aqui                         # Chave Groq (server-side, nunca exposta)
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxx      # Token do Mercado Pago
# WEBHOOK_BASE_URL=https://seu-projeto.vercel.app     # URL base para o webhook MP
# MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxx                 # Assinatura do webhook (MP: Suas integrações → Webhooks) — spec 0004
# FIREBASE_WEB_API_KEY=AIzaSy...                      # API key web do Firebase (obrigatória p/ /api/ai validar login) — spec 0004
# ALLOWED_ORIGINS=https://meudominio.com              # Origens extras de CORS além dos defaults (opcional) — spec 0004
#
# ── Firebase Admin SDK (para webhook ativar plano automaticamente) ──────────────
# Gere em: Firebase Console → Configurações → Contas de serviço → Gerar nova chave privada
# FIREBASE_PROJECT_ID=nexus-rpg-app
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@nexus-rpg-app.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
