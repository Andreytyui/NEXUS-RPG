rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users (perfil + plano) ─────────────────────────────────────────────────
    // plan/subscribedSystems são escritos APENAS pelo backend (service account não passa
    // pelas rules). Cliente não pode se dar plano (spec 0004 AC-1).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['subscribedSystems'])
        && (!('plan' in request.resource.data) || request.resource.data.plan == 'free');
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscribedSystems']);
      allow delete: if request.auth != null && request.auth.uid == userId;

      // ── Characters (fichas do usuário) ───────────────────────────────────────
      match /characters/{charId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Assets (biblioteca de mapa do usuário — spec 0013 / ADR 0006 §4) ──────
      // Coleção do próprio usuário, reutilizável entre campanhas. Só o dono lê/escreve;
      // imagens colocadas na cena são copiadas para a campanha (jogadores nunca leem daqui).
      match /assets/{assetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Campaigns ─────────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.masterId == request.auth.uid
        && request.resource.data.members.hasAll([request.auth.uid]);

      allow update: if request.auth != null
        && resource.data.masterId == request.auth.uid;

      // Membro existente pode atualizar apenas members/memberNames
      allow update: if request.auth != null
        && resource.data.members.hasAny([request.auth.uid])
        && onlyUpdatingFields(['members', 'memberNames']);

      // Qualquer usuário autenticado pode se ADICIONAR à campanha (entrar com código)
      allow update: if request.auth != null
        && !resource.data.members.hasAny([request.auth.uid])
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.hasAll([request.auth.uid])
        && onlyUpdatingFields(['members', 'memberNames']);

      allow delete: if request.auth != null
        && resource.data.masterId == request.auth.uid;

      // ── Messages ─────────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if request.auth != null && isMember(campaignId);
        allow create: if request.auth != null
          && isMember(campaignId)
          && (
            request.resource.data.userId == request.auth.uid
            || request.resource.data.userId == "system"
          );
        allow delete: if request.auth != null
          && (
            resource.data.userId == request.auth.uid
            || isMaster(campaignId)
          );
        allow update: if false;
      }

      // ── Typing indicators ────────────────────────────────────────────────────
      match /typing/{userId} {
        allow read:  if request.auth != null && isMember(campaignId);
        allow write: if request.auth != null && request.auth.uid == userId && isMember(campaignId);
      }

      // ── Shared Sheets ────────────────────────────────────────────────────────
      match /sharedSheets/{sheetId} {
        allow read: if request.auth != null && isMember(campaignId);
        allow create: if request.auth != null
          && isMember(campaignId)
          && request.resource.data.ownerId == request.auth.uid;
        allow delete: if request.auth != null
          && (
            resource.data.ownerId == request.auth.uid
            || isMaster(campaignId)
          );
        allow update: if request.auth != null
          && isMember(campaignId)
          && (
            // Dono sempre pode atualizar
            resource.data.ownerId == request.auth.uid
            // Mestre pode editar se allowMasterEdit != false (default true)
            || (isMaster(campaignId) && resource.data.characterData.allowMasterEdit != false)
            // Qualquer membro da campanha pode editar se allowAnyEdit == true
            || resource.data.characterData.allowAnyEdit == true
          );
      }

      // ── Mapa da campanha (VTT) v2 — spec 0009 / ADR 0006 ─────────────────────
      // Docs da coleção map: state (ponteiro), cenas s_* (meta), img_* (imutáveis),
      // live_{uid} (canal efêmero). Escrita geral só do mestre; membro escreve apenas
      // o próprio live_{uid}.
      match /map/{docId} {
        allow read: if request.auth != null && isMember(campaignId);
        allow write: if request.auth != null && isMaster(campaignId);
        allow write: if request.auth != null && isMember(campaignId)
          && docId == 'live_' + request.auth.uid;

        // Elementos da cena em docs próprios — jogador gated pelas permissions da cena
        // (dormente até a spec 0010; mestre tem write total).
        match /elements/{elId} {
          allow read: if request.auth != null && isMember(campaignId);
          allow write: if request.auth != null && isMaster(campaignId);
          allow create: if request.auth != null && isMember(campaignId)
            && request.resource.data.ownerId == request.auth.uid
            && layerPerm(campaignId, docId, request.resource.data.layerId, 'create') == true;
          allow update: if request.auth != null && isMember(campaignId)
            && resource.data.ownerId == request.auth.uid
            && layerPerm(campaignId, docId, resource.data.layerId, 'update') == 'owner'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['x', 'y', 'rotation']);
          allow delete: if request.auth != null && isMember(campaignId)
            && resource.data.ownerId == request.auth.uid
            && layerPerm(campaignId, docId, resource.data.layerId, 'delete') == 'owner';
        }
      }
    }

    // ── Public Sheets (fichas compartilháveis por link, sem login) ───────────
    match /publicSheets/{charId} {
      allow read: if true;
      // Dono obrigatório na criação; docs legados sem ownerUid podem ser
      // reivindicados pelo primeiro editor autenticado (retrocompat, spec 0004 AC-3).
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || !('ownerUid' in resource.data))
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || !('ownerUid' in resource.data));

      match /pendingEdits/{editId} {
        allow read: if true;
        // Sugestões continuam abertas (by design); resolver é só do dono da ficha.
        allow create: if true;
        allow update, delete: if request.auth != null
          && (
            !('ownerUid' in get(/databases/$(database)/documents/publicSheets/$(charId)).data)
            || get(/databases/$(database)/documents/publicSheets/$(charId)).data.ownerUid == request.auth.uid
          );
      }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isMember(campaignId) {
      return request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.members;
    }

    function isMaster(campaignId) {
      return request.auth.uid == get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId;
    }

    function onlyUpdatingFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // Permissão da camada declarada no doc da cena (spec 0009 / ADR 0006 §6).
    // Devolve o valor cru (true/'owner'/'all'/...) ou false se não configurada.
    function layerPerm(campaignId, sceneId, layerId, action) {
      let perms = get(/databases/$(database)/documents/campaigns/$(campaignId)/map/$(sceneId)).data.permissions;
      return (layerId in perms && action in perms[layerId]) ? perms[layerId][action] : false;
    }
  }
}
