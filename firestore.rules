rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users (perfil + plano) ─────────────────────────────────────────────────
    // plan/subscribedSystems são escritos APENAS pelo backend (service account não passa
    // pelas rules). Cliente não pode se dar plano (spec 0004 AC-1).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['subscribedSystems'])
        && (!('plan' in request.resource.data) || request.resource.data.plan == 'free');
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['plan', 'subscribedSystems']);
      allow delete: if request.auth != null && request.auth.uid == userId;

      // ── Characters (fichas do usuário) ───────────────────────────────────────
      match /characters/{charId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Campaigns ─────────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {

      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.masterId == request.auth.uid
        && request.resource.data.members.hasAll([request.auth.uid]);

      allow update: if request.auth != null
        && resource.data.masterId == request.auth.uid;

      // Membro existente pode atualizar apenas members/memberNames
      allow update: if request.auth != null
        && resource.data.members.hasAny([request.auth.uid])
        && onlyUpdatingFields(['members', 'memberNames']);

      // Qualquer usuário autenticado pode se ADICIONAR à campanha (entrar com código)
      allow update: if request.auth != null
        && !resource.data.members.hasAny([request.auth.uid])
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.hasAll([request.auth.uid])
        && onlyUpdatingFields(['members', 'memberNames']);

      allow delete: if request.auth != null
        && resource.data.masterId == request.auth.uid;

      // ── Messages ─────────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if request.auth != null && isMember(campaignId);
        allow create: if request.auth != null
          && isMember(campaignId)
          && (
            request.resource.data.userId == request.auth.uid
            || request.resource.data.userId == "system"
          );
        allow delete: if request.auth != null
          && (
            resource.data.userId == request.auth.uid
            || isMaster(campaignId)
          );
        allow update: if false;
      }

      // ── Typing indicators ────────────────────────────────────────────────────
      match /typing/{userId} {
        allow read:  if request.auth != null && isMember(campaignId);
        allow write: if request.auth != null && request.auth.uid == userId && isMember(campaignId);
      }

      // ── Shared Sheets ────────────────────────────────────────────────────────
      match /sharedSheets/{sheetId} {
        allow read: if request.auth != null && isMember(campaignId);
        allow create: if request.auth != null
          && isMember(campaignId)
          && request.resource.data.ownerId == request.auth.uid;
        allow delete: if request.auth != null
          && (
            resource.data.ownerId == request.auth.uid
            || isMaster(campaignId)
          );
        allow update: if request.auth != null
          && isMember(campaignId)
          && (
            // Dono sempre pode atualizar
            resource.data.ownerId == request.auth.uid
            // Mestre pode editar se allowMasterEdit != false (default true)
            || (isMaster(campaignId) && resource.data.characterData.allowMasterEdit != false)
            // Qualquer membro da campanha pode editar se allowAnyEdit == true
            || resource.data.characterData.allowAnyEdit == true
          );
      }

      // ── Mapa da campanha (VTT) — leitura p/ membros; escrita SÓ do mestre ────
      // (fecha o backlog do ADR 0005 §4; fase 2 do ping exigirá regra própria)
      match /map/{docId} {
        allow read: if request.auth != null && isMember(campaignId);
        allow write: if request.auth != null && isMaster(campaignId);
      }
    }

    // ── Public Sheets (fichas compartilháveis por link, sem login) ───────────
    match /publicSheets/{charId} {
      allow read: if true;
      // Dono obrigatório na criação; docs legados sem ownerUid podem ser
      // reivindicados pelo primeiro editor autenticado (retrocompat, spec 0004 AC-3).
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || !('ownerUid' in resource.data))
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || !('ownerUid' in resource.data));

      match /pendingEdits/{editId} {
        allow read: if true;
        // Sugestões continuam abertas (by design); resolver é só do dono da ficha.
        allow create: if true;
        allow update, delete: if request.auth != null
          && (
            !('ownerUid' in get(/databases/$(database)/documents/publicSheets/$(charId)).data)
            || get(/databases/$(database)/documents/publicSheets/$(charId)).data.ownerUid == request.auth.uid
          );
      }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isMember(campaignId) {
      return request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campaignId)).data.members;
    }

    function isMaster(campaignId) {
      return request.auth.uid == get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId;
    }

    function onlyUpdatingFields(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }
  }
}
